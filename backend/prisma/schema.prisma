// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  VISITOR
  CONTRIBUTOR
  DISTINGUISHED
  ELITE
  OWNER
  ADMIN
}

enum VerificationType {
  NONE
  ELITE
  OWNER
}

enum LactarioStatus {
  PENDING
  ACTIVE
  CLOSED
  MAINTENANCE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModerationEntityType {
  PHOTO
  LACTARIO
  REVIEW
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String
  role          Role     @default(VISITOR)
  points        Int      @default(0)
  syncEnabled   Boolean  @default(false)
  lastLogin     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  ownedLactarios     Lactario[] @relation("OwnerLactarios")
  reviews            Review[]
  nursingLogs        NursingLog[]
  maintenanceReports MaintenanceReport[]
  badges             UserBadge[]
}

model Badge {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String
  icon        String      // Lucide icon name or URL
  requiredPoints Int      @default(0)
  
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
}

model Lactario {
  id              String   @id @default(uuid())
  name            String
  // PostGIS Point support is usually handled via raw SQL or unsupported types in Prisma basic usage.
  // For this schema, we will store lat/lng as decimals for simplicity if PostGIS extension is complex to mock, 
  // but better to use unsupported type for real PostGIS.
  // Using unsupported to strictly follow requirements.
  geom            Unsupported("geometry(Point, 4326)")? 
  latitude        Decimal? // Fallback/Cache for easy access
  longitude       Decimal? // Fallback/Cache for easy access
  
  address         String?
  description     String?
  ownerId         String?
  owner           User?    @relation("OwnerLactarios", fields: [ownerId], references: [id])
  
  verifiedType    VerificationType @default(NONE)
  verificationCount Int            @default(0)
  status          LactarioStatus   @default(PENDING)
  avgRating       Decimal          @default(0.0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  amenities       LactarioAmenity?
  reviews         Review[]
  photos          Photo[]
  maintenanceReports MaintenanceReport[]
}

model LactarioAmenity {
  id               String   @id @default(uuid())
  lactarioId       String   @unique
  lactario         Lactario @relation(fields: [lactarioId], references: [id])
  
  hasFridge        Boolean  @default(false)
  hasPower         Boolean  @default(false)
  hasSink          Boolean  @default(false)
  hasPrivacy       Boolean  @default(false)
  hasNursingChair  Boolean  @default(false)
  isAccessible     Boolean  @default(false)
  hasAC            Boolean  @default(false)
  hasStrollerAccess Boolean @default(false)
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lactarioId  String
  lactario    Lactario @relation(fields: [lactarioId], references: [id])
  
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
}

model Photo {
  id               String   @id @default(uuid())
  lactarioId       String
  lactario         Lactario @relation(fields: [lactarioId], references: [id])
  url              String
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime @default(now())
}

model NursingLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  startTime    DateTime
  endTime      DateTime
  side         String // LEFT, RIGHT, BOTH
  volumeMl     Decimal
  sessionTotal Decimal
  
  createdAt    DateTime @default(now())
}

model MaintenanceReport {
  id           String   @id @default(uuid())
  lactarioId   String
  lactario     Lactario @relation(fields: [lactarioId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  issueType    String
  description  String?
  status       String   @default("OPEN") // OPEN, RESOLVED
  
  createdAt    DateTime @default(now())
}

model ModerationQueue {
  id              String               @id @default(uuid())
  entityType      ModerationEntityType
  entityId        String
  status          ModerationStatus     @default(PENDING)
  rejectionReason String?
  createdAt       DateTime             @default(now())
}
