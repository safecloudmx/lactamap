// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VISITOR
  CONTRIBUTOR
  DISTINGUISHED
  ELITE
  OWNER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum VerificationType {
  NONE
  ELITE
  OWNER
}

enum LactarioStatus {
  PENDING
  ACTIVE
  CLOSED
  MAINTENANCE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModerationEntityType {
  PHOTO
  LACTARIO
  REVIEW
}

enum RejectionReason {
  OBSCENE_CONTENT
  INCORRECT_CONTENT
  INTERNAL_TEST
  DUPLICATE
  LOW_QUALITY_PHOTO
  INCORRECT_LOCATION
  OTHER
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String
  role                Role          @default(VISITOR)
  status              AccountStatus @default(ACTIVE)
  points              Int           @default(0)
  syncEnabled         Boolean       @default(false)
  failedLoginAttempts Int           @default(0)
  lockedUntil         DateTime?
  emailVerified       Boolean       @default(false)
  emailVerifyOtp      String?
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?       @unique
  passwordResetExpiry DateTime?
  lastLogin           DateTime      @default(now())
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  incorrectContentCount Int           @default(0)
  avatarUrl             String?

  // Relations
  ownedLactarios        Lactario[]             @relation("OwnerLactarios")
  reviews               Review[]
  babies                Baby[]
  nursingSessions       NursingSession[]
  maintenanceReports    MaintenanceReport[]
  badges                UserBadge[]
  submissions           LactarioSubmission[]   @relation("SubmittedBy")
  reviewedSubmissions   LactarioSubmission[]   @relation("ReviewedBy")
  editProposals         LactarioEditProposal[] @relation("ProposedEdits")
  reviewedEditProposals LactarioEditProposal[] @relation("ReviewedEdits")
  reviewReports         ReviewReport[]
}

model Badge {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  description String
  icon        String      // Lucide icon name or URL
  requiredPoints Int      @default(0)
  
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
}

model Lactario {
  id              String   @id @default(uuid())
  name            String
  latitude        Decimal?
  longitude       Decimal?
  
  address         String?
  description     String?
  ownerId         String?
  owner           User?    @relation("OwnerLactarios", fields: [ownerId], references: [id])
  
  verifiedType    VerificationType @default(NONE)
  verificationCount Int            @default(0)
  status          LactarioStatus   @default(PENDING)
  avgRating       Decimal          @default(0.0)
  tags            String[]         @default([])
  placeType       String           @default("LACTARIO")
  genderAccess    String           @default("Unisex/Familiar")
  imageUrl        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  amenities          LactarioAmenity?
  reviews            Review[]
  photos             Photo[]
  maintenanceReports MaintenanceReport[]
  submission         LactarioSubmission?
  editProposals      LactarioEditProposal[]
}

model LactarioAmenity {
  id               String   @id @default(uuid())
  lactarioId       String   @unique
  lactario         Lactario @relation(fields: [lactarioId], references: [id])
  
  hasFridge        Boolean  @default(false)
  hasPower         Boolean  @default(false)
  hasSink          Boolean  @default(false)
  hasPrivacy       Boolean  @default(false)
  hasNursingChair  Boolean  @default(false)
  isAccessible     Boolean  @default(false)
  hasAC            Boolean  @default(false)
  hasStrollerAccess Boolean @default(false)
  isInBathroom     Boolean  @default(false)
  isOpen           Boolean  @default(false)
}

model Review {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lactarioId  String
  lactario    Lactario @relation(fields: [lactarioId], references: [id])

  rating      Int
  comment     String?
  reportCount Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  reports     ReviewReport[]

  @@unique([userId, lactarioId])
}

model ReviewReport {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model Photo {
  id               String   @id @default(uuid())
  lactarioId       String
  lactario         Lactario @relation(fields: [lactarioId], references: [id])
  url              String
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime @default(now())
}

model Baby {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  birthDate DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nursingSessions NursingSession[]
}

model NursingSession {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  babyId         String?
  baby           Baby?    @relation(fields: [babyId], references: [id])

  startedAt      DateTime
  endedAt        DateTime
  leftDuration   Int      // seconds
  rightDuration  Int      // seconds
  totalDuration  Int      // seconds
  totalPauseTime Int      @default(0)
  lastSide       String   // left, right, both
  notes          String?

  createdAt      DateTime @default(now())
}

model MaintenanceReport {
  id           String   @id @default(uuid())
  lactarioId   String
  lactario     Lactario @relation(fields: [lactarioId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  issueType    String
  description  String?
  status       String   @default("OPEN") // OPEN, RESOLVED
  
  createdAt    DateTime @default(now())
}

model LactarioSubmission {
  id              String            @id @default(uuid())
  lactarioId      String            @unique
  lactario        Lactario          @relation(fields: [lactarioId], references: [id], onDelete: Cascade)

  submittedById   String
  submittedBy     User              @relation("SubmittedBy", fields: [submittedById], references: [id])

  status          ModerationStatus  @default(PENDING)
  rejectionReason RejectionReason?
  rejectionNotes  String?

  reviewedById    String?
  reviewedBy      User?             @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?

  createdAt       DateTime          @default(now())
}

model LactarioEditProposal {
  id            String           @id @default(uuid())
  lactarioId    String
  lactario      Lactario         @relation(fields: [lactarioId], references: [id], onDelete: Cascade)
  proposedById  String
  proposedBy    User             @relation("ProposedEdits", fields: [proposedById], references: [id])

  name          String?
  address       String?
  description   String?
  amenities     String[]         @default([])
  tags          String[]         @default([])

  status        ModerationStatus @default(PENDING)
  reviewedById  String?
  reviewedBy    User?            @relation("ReviewedEdits", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  rejectionNotes String?

  createdAt     DateTime         @default(now())
}

model ModerationQueue {
  id              String               @id @default(uuid())
  entityType      ModerationEntityType
  entityId        String
  status          ModerationStatus     @default(PENDING)
  rejectionReason String?
  createdAt       DateTime             @default(now())
}
